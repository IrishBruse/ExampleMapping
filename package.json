{
    "name": "example-mapping",
    "version": "1.0.0",
    "description": "Collaborative Markdown Sticky Generator",
    "main": "dist/server.js",
    "bin": {
        "example-mapping": "./dist/cli.js"
    },
    "scripts": {
        "build:client": "cd client && npm run build",
        "build:server": "tsc",
        "build": "npm run build:server && npm run build:client",
        "dev": "npm run build:client && tsx watch src/server.ts",
        "start": "node dist/cli.js",
        "install-global": "bash scripts/install-global.sh"
    },
    "dependencies": {
        "express": "^4.18.2",
        "socket.io": "^4.7.2",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "tsx": "4.21.0",
        "typescript": "^5.3.2"
    }
}
