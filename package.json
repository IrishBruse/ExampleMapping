{
  "name": "mapping-tool",
  "version": "1.0.0",
  "description": "Collaborative Markdown Sticky Generator",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "build": "npm run build:server && npm run build:client",
    "dev:server": "ts-node src/server.ts",
    "dev:client": "cd client && npm run dev",
    "start": "node dist/server.js",
    "watch": "tsc --watch",
    "install:all": "npm install && cd client && npm install",
    "share": "bash scripts/share.sh"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
