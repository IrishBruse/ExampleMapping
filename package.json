{
    "name": "mapping-tool",
    "version": "1.0.0",
    "description": "Collaborative Markdown Sticky Generator",
    "main": "dist/server.js",
    "scripts": {
        "build:client": "cd client && npm run build",
        "build": "npm run build:server && npm run build:client",
        "dev": "npm run build:client && tsx watch src/server.ts",
        "share": "bash scripts/share.sh"
    },
    "dependencies": {
        "express": "^4.18.2",
        "socket.io": "^4.7.2"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "tsx": "4.21.0",
        "typescript": "^5.3.2"
    }
}
